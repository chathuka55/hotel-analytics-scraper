# --- Environment ---
ENV=development
DEBUG=true
LOG_LEVEL=INFO

# --- Scraping ---
REQUEST_TIMEOUT=30
MAX_RETRIES=3
RETRY_DELAY=2
CONCURRENT_REQUESTS=5
RATE_LIMIT_PER_SECOND=0.5
USER_AGENT_ROTATION=true
PROXY_ROTATION=false

# --- Proxy (if enabled) ---
# PROXY_LIST=http://proxy1:8080,http://proxy2:8080
# PROXY_USERNAME=
# PROXY_PASSWORD=

# --- Database ---
DATABASE_URL=sqlite:///data/hotel_scraper.db
# DATABASE_URL=postgresql://user:password@localhost:5432/hotel_scraper

# --- Playwright ---
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_BROWSER=chromium
PLAYWRIGHT_SLOW_MO=500

# --- Sources ---
BOOKING_BASE_URL=https://www.booking.com
AGODA_BASE_URL=https://www.agoda.com
EXPEDIA_BASE_URL=https://www.expedia.com
SLTDA_BASE_URL=https://www.sltda.gov.lk
DATAGOVLK_BASE_URL=https://www.data.gov.lk

# --- Scheduling ---
SCHEDULE_INTERVAL_HOURS=24
SCHEDULE_TIME=02:00

# --- Monitoring ---
METRICS_PORT=9090
ENABLE_PROMETHEUS=false

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1
# Comma-separated allowed browser origins (local + Vercel)
FRONTEND_ORIGIN=http://localhost:5173,https://hotel-analytics-scraper.vercel.app

# --- Frontend (Vite) ---
# Leave unset on Vercel fullstack (same-origin /api). For split hosting set e.g.:
# VITE_API_BASE_URL=https://your-api.onrender.com
